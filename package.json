{
  "name": "agentic-commerce-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Agentic-first, multi-tenant e-commerce platform for India (Razorpay/GoKwik/WhatsApp) with a REST API and an MCP server over one shared service layer.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "prisma:generate": "pnpm --filter @acp/core prisma:generate",
    "prisma:migrate": "pnpm --filter @acp/core prisma:migrate",
    "seed": "pnpm --filter @acp/core seed",
    "api:dev": "pnpm --filter @acp/api dev",
    "mcp:dev": "pnpm --filter @acp/mcp dev",
    "worker:dev": "pnpm --filter @acp/worker dev",
    "admin:dev": "pnpm --filter acp-admin dev",
    "admin:build": "pnpm --filter acp-admin build",
    "store:dev": "pnpm --filter acp-storefront dev",
    "store:build": "pnpm --filter acp-storefront build",
    "platform:dev": "pnpm --filter acp-platform dev",
    "platform:build": "pnpm --filter acp-platform build",
    "partner:dev": "pnpm --filter acp-partner dev",
    "partner:build": "pnpm --filter acp-partner build"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}
