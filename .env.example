# --- Database ---
# Matches docker-compose.yml. Override host/port if you run Postgres elsewhere.
DATABASE_URL="postgresql://acp:acp@localhost:5432/acp?schema=public"

# --- Encryption ---
# 32-byte key (base64) used to encrypt integration credentials at rest.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CORE_ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_BASE64_KEY"

# --- REST API (apps/api) ---
API_PORT=3000

# --- MCP server (apps/mcp) ---
# Transport: "stdio" (for Claude Code) or "http" (Streamable HTTP for remote clients).
MCP_TRANSPORT="stdio"
MCP_HTTP_PORT=3333
# API key the MCP server uses to authenticate against the core service layer.
# In stdio mode this is read from the environment; for HTTP it is sent per-request.
ACP_API_KEY=""

# --- Support assistant (platform console) ---
# Optional. When set, the operator support chatbot uses Claude (tool use over
# platform data). When unset, a deterministic rules-based stub answers instead.
ANTHROPIC_API_KEY=""

# --- Authentication: OAuth + 2FA (optional) ---
# Google/Apple OAuth audience validation (id-token verification works without
# these, but set them in production to reject tokens minted for other apps).
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
# Label shown in authenticator apps for TOTP 2FA.
TWO_FA_ISSUER=ACP Commerce
