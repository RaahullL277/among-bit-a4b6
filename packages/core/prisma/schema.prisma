// Agentic Commerce Platform — core domain model.
// Multi-tenant SaaS: every domain row carries a tenantId and is isolated by the service layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum StoreStatus {
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

// Category of an integration (what the provider does).
enum IntegrationKind {
  PAYMENT
  MESSAGING
}

// Concrete provider implementations available behind the adapter interfaces.
enum ProviderName {
  RAZORPAY
  GOKWIK
  WHATSAPP
  RESEND
  MSG91
}

// Delivery channels for customer/store-owner notifications.
enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

// Business events that can trigger a notification.
enum NotificationEvent {
  ORDER_PLACED
  ORDER_PAID
  ORDER_STATUS_CHANGED
  ABANDONED_CART
  LOW_STOCK
  OUT_OF_STOCK
}

// Who a notification is addressed to.
enum RecipientType {
  CUSTOMER
  STORE_OWNER
}

enum NotificationStatus {
  SENT
  FAILED
  SKIPPED
}

// Lifecycle of a shopping cart.
enum CartStatus {
  ACTIVE     // shopper is adding items
  ABANDONED  // idle past the threshold; recovery in progress
  CONVERTED  // checked out and paid (never abandoned)
  RECOVERED  // was abandoned, then converted
}

// Traffic-light stock health for a variant.
enum StockStatus {
  GREEN  // healthy cover
  AMBER  // running low
  RED    // critical / out of stock
}

// ---------------------------------------------------------------------------
// Account / tenancy
// ---------------------------------------------------------------------------

// Roles for a user within a tenant, in descending order of privilege.
enum Role {
  OWNER
  ADMIN
  STAFF
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores        Store[]
  apiKeys       ApiKey[]
  installations AppInstallation[]
  memberships   Membership[]
  invites       Invite[]
}

// Global user identity. A user can belong to multiple tenants via Membership.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  sessions    Session[]
}

// A user's role within a specific tenant.
model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

// Pending invitation to join a tenant with a given role (passwordless).
model Invite {
  id        String    @id @default(cuid())
  tenantId  String
  email     String
  role      Role      @default(STAFF)
  tokenHash String    @unique
  expiresAt DateTime
  acceptedAt DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([email])
}

// Single-use passwordless login token, emailed as a magic link.
model MagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

// An authenticated browser session for the admin console (Bearer token).
model Session {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String
  tokenHash  String   @unique
  expiresAt  DateTime
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  // Only the SHA-256 hash of the raw key is stored. `prefix` is a non-secret
  // lookup hint shown in dashboards (e.g. "sk_live_a1b2").
  keyHash    String    @unique
  prefix     String
  scopes     String[]  @default([])
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Storefront domain
// ---------------------------------------------------------------------------

model Store {
  id        String      @id @default(cuid())
  tenantId  String
  name      String
  slug      String
  domain    String?
  currency  String      @default("INR")
  country   String      @default("IN")
  status    StoreStatus @default(ACTIVE)
  // Where store-owner notifications (stock alerts, new orders) are sent.
  // Phase 2 will derive these from user memberships; explicit for now.
  ownerEmail String?
  ownerPhone String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenant       Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products     Product[]
  collections  Collection[]
  customers    Customer[]
  orders       Order[]
  integrations IntegrationConfig[]
  notifications Notification[]
  notificationPreferences NotificationPreference[]
  carts        Cart[]
  cartRecoveryPolicy CartRecoveryPolicy?
  stockPolicy  StockPolicy?

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Product {
  id          String        @id @default(cuid())
  tenantId    String
  storeId     String
  title       String
  description String?
  status      ProductStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants ProductVariant[]

  @@index([tenantId])
  @@index([storeId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  tenantId  String
  productId String
  title     String  @default("Default")
  sku       String?
  // Price is stored in the smallest currency unit (paise for INR).
  priceMinor Int
  currency  String  @default("INR")
  inventory Int     @default(0)
  options   Json?
  // Last computed stock health, used to detect transitions for alerting.
  lastStockStatus StockStatus?

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([tenantId])
  @@index([productId])
}

model Collection {
  id        String   @id @default(cuid())
  tenantId  String
  storeId   String
  title     String
  handle    String
  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, handle])
  @@index([tenantId])
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  storeId   String
  name      String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store  Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([tenantId])
  @@index([storeId])
}

model Order {
  id         String      @id @default(cuid())
  tenantId   String
  storeId    String
  number     Int
  customerId String?
  // Set when an order originates from a cart, so recovery can be attributed.
  cartId     String?
  status     OrderStatus @default(PENDING)
  totalMinor Int
  currency   String      @default("INR")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  store    Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  cart     Cart?       @relation(fields: [cartId], references: [id], onDelete: SetNull)
  items    OrderItem[]
  payment  Payment?

  @@unique([storeId, number])
  @@index([tenantId])
  @@index([storeId])
  @@index([cartId])
}

model OrderItem {
  id             String  @id @default(cuid())
  tenantId       String
  orderId        String
  variantId      String?
  title          String
  quantity       Int     @default(1)
  unitPriceMinor Int

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model Payment {
  id          String        @id @default(cuid())
  tenantId    String
  orderId     String        @unique
  provider    ProviderName
  providerRef String?
  status      PaymentStatus @default(PENDING)
  amountMinor Int
  currency    String        @default("INR")
  raw         Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([providerRef])
}

// ---------------------------------------------------------------------------
// Integrations (pluggable adapters)
// ---------------------------------------------------------------------------

model IntegrationConfig {
  id        String          @id @default(cuid())
  tenantId  String
  storeId   String
  kind      IntegrationKind
  provider  ProviderName
  // Credentials are encrypted at rest (AES-256-GCM) before being stored here.
  config    Json
  enabled   Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, provider])
  @@index([tenantId])
}

model WebhookEvent {
  id             String       @id @default(cuid())
  tenantId       String?
  provider       ProviderName
  eventType      String?
  signatureValid Boolean      @default(false)
  payload        Json
  receivedAt     DateTime     @default(now())

  @@index([provider])
}

// ---------------------------------------------------------------------------
// Partner app ecosystem (schema stubbed; minimal logic in Milestone 1)
// ---------------------------------------------------------------------------

model App {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  scopes      String[] @default([])
  createdAt   DateTime @default(now())

  installations AppInstallation[]
}

model AppInstallation {
  id        String   @id @default(cuid())
  tenantId  String
  appId     String
  config    Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  app    App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([tenantId, appId])
  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Notifications (email / SMS / WhatsApp to customers and store owners)
// ---------------------------------------------------------------------------

// Per-store override of the message body for an (event, channel). When absent,
// a built-in default template (in code) is used, so seeding is optional.
model NotificationTemplate {
  id        String              @id @default(cuid())
  tenantId  String
  storeId   String
  event     NotificationEvent
  channel   NotificationChannel
  subject   String?
  body      String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([storeId, event, channel])
  @@index([tenantId])
}

// Which channels fire for an (event, recipient) in a store. When absent, a
// built-in default preference (in code) decides.
model NotificationPreference {
  id            String                @id @default(cuid())
  tenantId      String
  storeId       String
  event         NotificationEvent
  recipientType RecipientType
  channels      NotificationChannel[] @default([])
  enabled       Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, event, recipientType])
  @@index([tenantId])
}

// Audit log of every notification dispatch attempt.
model Notification {
  id            String              @id @default(cuid())
  tenantId      String
  storeId       String
  event         NotificationEvent
  channel       NotificationChannel
  recipientType RecipientType
  to            String
  status        NotificationStatus
  providerRef   String?
  error         String?
  createdAt     DateTime            @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([storeId])
}

// ---------------------------------------------------------------------------
// Carts & abandoned-cart recovery
// ---------------------------------------------------------------------------

model Cart {
  id           String     @id @default(cuid())
  tenantId     String
  storeId      String
  customerId   String?
  // Contact for an anonymous shopper (used for recovery messages).
  contactEmail String?
  contactPhone String?
  status       CartStatus @default(ACTIVE)
  lastActivityAt DateTime @default(now())
  abandonedAt  DateTime?
  // How many recovery steps have already been sent for this cart.
  recoveryStepsSent Int    @default(0)
  lastRecoveryAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  store Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items CartItem[]
  orders Order[]

  @@index([tenantId])
  @@index([storeId])
  @@index([status])
}

model CartItem {
  id             String @id @default(cuid())
  tenantId       String
  cartId         String
  variantId      String
  title          String
  quantity       Int    @default(1)
  unitPriceMinor Int

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@index([cartId])
}

// Per-store stock-alert thresholds (drives the R/A/G scorer).
model StockPolicy {
  id                 String   @id @default(cuid())
  tenantId           String
  storeId            String   @unique
  enabled            Boolean  @default(true)
  // Days-of-cover boundaries: >= greenDays is GREEN, >= amberDays is AMBER.
  greenDays          Int      @default(14)
  amberDays          Int      @default(5)
  // Inventory at or below this is always RED (manual reorder point).
  reorderPoint       Int      @default(0)
  // Trailing window (days) used to compute sales velocity.
  velocityWindowDays Int      @default(30)
  updatedAt          DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Per-store abandoned-cart recovery configuration.
model CartRecoveryPolicy {
  id                 String   @id @default(cuid())
  tenantId           String
  storeId            String   @unique
  enabled            Boolean  @default(true)
  // A cart idle for this many minutes becomes ABANDONED.
  abandonAfterMinutes Int     @default(60)
  // Delays (minutes after abandonment) at which each recovery message is sent.
  stepDelaysMinutes  Int[]    @default([0, 1440, 4320])
  updatedAt          DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}
