// Agentic Commerce Platform — core domain model.
// Multi-tenant SaaS: every domain row carries a tenantId and is isolated by the service layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum StoreStatus {
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

// Category of an integration (what the provider does).
enum IntegrationKind {
  PAYMENT
  MESSAGING
}

// Concrete provider implementations available behind the adapter interfaces.
enum ProviderName {
  RAZORPAY
  GOKWIK
  WHATSAPP
}

// ---------------------------------------------------------------------------
// Account / tenancy
// ---------------------------------------------------------------------------

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores        Store[]
  apiKeys       ApiKey[]
  installations AppInstallation[]
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  // Only the SHA-256 hash of the raw key is stored. `prefix` is a non-secret
  // lookup hint shown in dashboards (e.g. "sk_live_a1b2").
  keyHash    String    @unique
  prefix     String
  scopes     String[]  @default([])
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Storefront domain
// ---------------------------------------------------------------------------

model Store {
  id        String      @id @default(cuid())
  tenantId  String
  name      String
  slug      String
  domain    String?
  currency  String      @default("INR")
  country   String      @default("IN")
  status    StoreStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products     Product[]
  collections  Collection[]
  customers    Customer[]
  orders       Order[]
  integrations IntegrationConfig[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Product {
  id          String        @id @default(cuid())
  tenantId    String
  storeId     String
  title       String
  description String?
  status      ProductStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants ProductVariant[]

  @@index([tenantId])
  @@index([storeId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  tenantId  String
  productId String
  title     String  @default("Default")
  sku       String?
  // Price is stored in the smallest currency unit (paise for INR).
  priceMinor Int
  currency  String  @default("INR")
  inventory Int     @default(0)
  options   Json?

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([tenantId])
  @@index([productId])
}

model Collection {
  id        String   @id @default(cuid())
  tenantId  String
  storeId   String
  title     String
  handle    String
  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, handle])
  @@index([tenantId])
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  storeId   String
  name      String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store  Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([tenantId])
  @@index([storeId])
}

model Order {
  id         String      @id @default(cuid())
  tenantId   String
  storeId    String
  number     Int
  customerId String?
  status     OrderStatus @default(PENDING)
  totalMinor Int
  currency   String      @default("INR")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  store    Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    OrderItem[]
  payment  Payment?

  @@unique([storeId, number])
  @@index([tenantId])
  @@index([storeId])
}

model OrderItem {
  id             String  @id @default(cuid())
  tenantId       String
  orderId        String
  variantId      String?
  title          String
  quantity       Int     @default(1)
  unitPriceMinor Int

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model Payment {
  id          String        @id @default(cuid())
  tenantId    String
  orderId     String        @unique
  provider    ProviderName
  providerRef String?
  status      PaymentStatus @default(PENDING)
  amountMinor Int
  currency    String        @default("INR")
  raw         Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([providerRef])
}

// ---------------------------------------------------------------------------
// Integrations (pluggable adapters)
// ---------------------------------------------------------------------------

model IntegrationConfig {
  id        String          @id @default(cuid())
  tenantId  String
  storeId   String
  kind      IntegrationKind
  provider  ProviderName
  // Credentials are encrypted at rest (AES-256-GCM) before being stored here.
  config    Json
  enabled   Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, provider])
  @@index([tenantId])
}

model WebhookEvent {
  id             String       @id @default(cuid())
  tenantId       String?
  provider       ProviderName
  eventType      String?
  signatureValid Boolean      @default(false)
  payload        Json
  receivedAt     DateTime     @default(now())

  @@index([provider])
}

// ---------------------------------------------------------------------------
// Partner app ecosystem (schema stubbed; minimal logic in Milestone 1)
// ---------------------------------------------------------------------------

model App {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  scopes      String[] @default([])
  createdAt   DateTime @default(now())

  installations AppInstallation[]
}

model AppInstallation {
  id        String   @id @default(cuid())
  tenantId  String
  appId     String
  config    Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  app    App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([tenantId, appId])
  @@index([tenantId])
}
