// Agentic Commerce Platform — core domain model.
// Multi-tenant SaaS: every domain row carries a tenantId and is isolated by the service layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum StoreStatus {
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

// Category of an integration (what the provider does).
enum IntegrationKind {
  PAYMENT
  MESSAGING
  SHIPPING
  MARKETING
}

// Concrete provider implementations available behind the adapter interfaces.
enum ProviderName {
  RAZORPAY
  GOKWIK
  WHATSAPP
  RESEND
  MSG91
  DELHIVERY
  KLAVIYO
  MAILCHIMP
  BREVO
}

// Lifecycle of a shipment (Delhivery-style).
enum ShipmentStatus {
  PENDING            // created locally, no AWB yet
  MANIFESTED         // AWB assigned / handed to courier
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RTO                // return to origin
  CANCELLED
  FAILED
}

// Delivery channels for customer/store-owner notifications.
enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

// Business events that can trigger a notification.
enum NotificationEvent {
  ORDER_PLACED
  ORDER_PAID
  ORDER_STATUS_CHANGED
  ABANDONED_CART
  LOW_STOCK
  OUT_OF_STOCK
  SHIPMENT_CREATED
  OUT_FOR_DELIVERY
  DELIVERED
  REVIEW_REQUEST
  RETURN_REQUESTED
  RETURN_APPROVED
  RETURN_REJECTED
  RETURN_REFUNDED
}

// Lifecycle of a return / RMA.
enum ReturnStatus {
  REQUESTED  // customer asked to return
  APPROVED   // merchant authorized; awaiting the item back
  REJECTED   // merchant declined
  RECEIVED   // returned item received by the merchant
  REFUNDED   // money returned to the customer
  CANCELLED  // withdrawn
}

// Why a customer is returning items.
enum ReturnReason {
  DAMAGED
  WRONG_ITEM
  NOT_AS_DESCRIBED
  NO_LONGER_NEEDED
  OTHER
}

// Kind of loyalty-points ledger entry.
enum LoyaltyTxnType {
  EARN    // earned from a paid order
  REDEEM  // spent for a discount
  SIGNUP  // joining bonus
  ADJUST  // manual merchant adjustment
}

// Moderation state of a product review.
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// How a bundle's saving is expressed.
enum DiscountType {
  PERCENT // discountValue = percent off (0..100)
  FIXED   // discountValue = flat amount off, in minor units
}

// Publish state of a builder-authored storefront page.
enum PageStatus {
  DRAFT
  PUBLISHED
}

// Who a notification is addressed to.
enum RecipientType {
  CUSTOMER
  STORE_OWNER
}

enum NotificationStatus {
  SENT
  FAILED
  SKIPPED
}

// Lifecycle of a shopping cart.
enum CartStatus {
  ACTIVE     // shopper is adding items
  ABANDONED  // idle past the threshold; recovery in progress
  CONVERTED  // checked out and paid (never abandoned)
  RECOVERED  // was abandoned, then converted
}

// Traffic-light stock health for a variant.
enum StockStatus {
  GREEN  // healthy cover
  AMBER  // running low
  RED    // critical / out of stock
}

// A customer-support conversation's state.
enum SupportConversationStatus {
  OPEN       // bot/customer exchange in progress
  ESCALATED  // flagged for a human agent
  RESOLVED   // closed
}

// Who authored a support message.
enum SupportSender {
  CUSTOMER
  BOT
  AGENT
}

// ---------------------------------------------------------------------------
// Account / tenancy
// ---------------------------------------------------------------------------

// Roles for a user within a tenant, in descending order of privilege.
enum Role {
  OWNER
  ADMIN
  STAFF
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

// Roles for staff of the platform operator (the SaaS company), distinct from
// per-tenant merchant roles.
enum PlatformRole {
  SUPER_ADMIN
  SUPPORT
  BILLING
  READ_ONLY
}

enum PlanTier {
  FREE
  GROWTH
  ENTERPRISE
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  stores        Store[]
  apiKeys       ApiKey[]
  installations AppInstallation[]
  memberships   Membership[]
  invites       Invite[]
  plan          TenantPlan?
}

// Plan tier + feature flags/limits for a tenant, set by platform billing staff.
// (Billing integration itself is out of scope — these are the operator flags.)
model TenantPlan {
  id         String   @id @default(cuid())
  tenantId   String   @unique
  tier       PlanTier @default(FREE)
  // null = unlimited; otherwise the max number of stores allowed.
  storeLimit Int?
  features   String[] @default([])
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// Global user identity. A user can belong to multiple tenants via Membership.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  sessions    Session[]
}

// A user's role within a specific tenant.
model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

// Pending invitation to join a tenant with a given role (passwordless).
model Invite {
  id        String    @id @default(cuid())
  tenantId  String
  email     String
  role      Role      @default(STAFF)
  tokenHash String    @unique
  expiresAt DateTime
  acceptedAt DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([email])
}

// Single-use passwordless login token, emailed as a magic link.
model MagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

// An authenticated browser session for the admin console (Bearer token).
model Session {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String
  tokenHash  String   @unique
  expiresAt  DateTime
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  // Only the SHA-256 hash of the raw key is stored. `prefix` is a non-secret
  // lookup hint shown in dashboards (e.g. "sk_live_a1b2").
  keyHash    String    @unique
  prefix     String
  scopes     String[]  @default([])
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Storefront domain
// ---------------------------------------------------------------------------

model Store {
  id        String      @id @default(cuid())
  tenantId  String
  name      String
  slug      String
  domain    String?
  currency  String      @default("INR")
  country   String      @default("IN")
  status    StoreStatus @default(ACTIVE)
  // Where store-owner notifications (stock alerts, new orders) are sent.
  // Phase 2 will derive these from user memberships; explicit for now.
  ownerEmail String?
  ownerPhone String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenant       Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products     Product[]
  collections  Collection[]
  customers    Customer[]
  orders       Order[]
  integrations IntegrationConfig[]
  notifications Notification[]
  notificationPreferences NotificationPreference[]
  carts        Cart[]
  cartRecoveryPolicy CartRecoveryPolicy?
  stockPolicy  StockPolicy?
  shipments    Shipment[]
  supportConversations SupportConversation[]
  supportBotConfig SupportBotConfig?
  reviews      Review[]
  bundles      Bundle[]
  pages        StorePage[]
  theme        StoreTheme?
  returns      Return[]
  loyaltyProgram LoyaltyProgram?

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Product {
  id          String        @id @default(cuid())
  tenantId    String
  storeId     String
  title       String
  description String?
  status      ProductStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants ProductVariant[]
  reviews  Review[]

  @@index([tenantId])
  @@index([storeId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  tenantId  String
  productId String
  title     String  @default("Default")
  sku       String?
  // Price is stored in the smallest currency unit (paise for INR).
  priceMinor Int
  currency  String  @default("INR")
  inventory Int     @default(0)
  options   Json?
  // Last computed stock health, used to detect transitions for alerting.
  lastStockStatus StockStatus?

  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  bundleItems BundleItem[]

  @@index([tenantId])
  @@index([productId])
}

model Collection {
  id        String   @id @default(cuid())
  tenantId  String
  storeId   String
  title     String
  handle    String
  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, handle])
  @@index([tenantId])
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  storeId   String
  name      String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders         Order[]
  loyaltyAccount LoyaltyAccount?

  @@index([tenantId])
  @@index([storeId])
}

model Order {
  id         String      @id @default(cuid())
  tenantId   String
  storeId    String
  number     Int
  customerId String?
  // Set when an order originates from a cart, so recovery can be attributed.
  cartId     String?
  status     OrderStatus @default(PENDING)
  // totalMinor is the amount actually charged (after any bundle discount).
  totalMinor Int
  // Bundle/offer savings applied at checkout, in minor units (0 = none).
  discountMinor Int      @default(0)
  currency   String      @default("INR")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  store    Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  cart     Cart?       @relation(fields: [cartId], references: [id], onDelete: SetNull)
  items    OrderItem[]
  payment  Payment?
  shipment Shipment?
  returns  Return[]

  @@unique([storeId, number])
  @@index([tenantId])
  @@index([storeId])
  @@index([cartId])
}

model OrderItem {
  id             String  @id @default(cuid())
  tenantId       String
  orderId        String
  variantId      String?
  title          String
  quantity       Int     @default(1)
  unitPriceMinor Int

  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  returnItems ReturnItem[]

  @@index([orderId])
}

model Payment {
  id          String        @id @default(cuid())
  tenantId    String
  orderId     String        @unique
  provider    ProviderName
  providerRef String?
  status      PaymentStatus @default(PENDING)
  amountMinor Int
  currency    String        @default("INR")
  raw         Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([providerRef])
}

// ---------------------------------------------------------------------------
// Integrations (pluggable adapters)
// ---------------------------------------------------------------------------

model IntegrationConfig {
  id        String          @id @default(cuid())
  tenantId  String
  storeId   String
  kind      IntegrationKind
  provider  ProviderName
  // Credentials are encrypted at rest (AES-256-GCM) before being stored here.
  config    Json
  enabled   Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, provider])
  @@index([tenantId])
}

model WebhookEvent {
  id             String       @id @default(cuid())
  tenantId       String?
  provider       ProviderName
  eventType      String?
  signatureValid Boolean      @default(false)
  payload        Json
  receivedAt     DateTime     @default(now())

  @@index([provider])
}

// ---------------------------------------------------------------------------
// Partner app ecosystem (schema stubbed; minimal logic in Milestone 1)
// ---------------------------------------------------------------------------

model App {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  scopes      String[] @default([])
  createdAt   DateTime @default(now())

  installations AppInstallation[]
}

model AppInstallation {
  id        String   @id @default(cuid())
  tenantId  String
  appId     String
  config    Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  app    App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([tenantId, appId])
  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Notifications (email / SMS / WhatsApp to customers and store owners)
// ---------------------------------------------------------------------------

// Per-store override of the message body for an (event, channel). When absent,
// a built-in default template (in code) is used, so seeding is optional.
model NotificationTemplate {
  id        String              @id @default(cuid())
  tenantId  String
  storeId   String
  event     NotificationEvent
  channel   NotificationChannel
  subject   String?
  body      String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([storeId, event, channel])
  @@index([tenantId])
}

// Which channels fire for an (event, recipient) in a store. When absent, a
// built-in default preference (in code) decides.
model NotificationPreference {
  id            String                @id @default(cuid())
  tenantId      String
  storeId       String
  event         NotificationEvent
  recipientType RecipientType
  channels      NotificationChannel[] @default([])
  enabled       Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, event, recipientType])
  @@index([tenantId])
}

// Audit log of every notification dispatch attempt.
model Notification {
  id            String              @id @default(cuid())
  tenantId      String
  storeId       String
  event         NotificationEvent
  channel       NotificationChannel
  recipientType RecipientType
  to            String
  status        NotificationStatus
  providerRef   String?
  error         String?
  createdAt     DateTime            @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([storeId])
}

// ---------------------------------------------------------------------------
// Carts & abandoned-cart recovery
// ---------------------------------------------------------------------------

model Cart {
  id           String     @id @default(cuid())
  tenantId     String
  storeId      String
  customerId   String?
  // Contact for an anonymous shopper (used for recovery messages).
  contactEmail String?
  contactPhone String?
  status       CartStatus @default(ACTIVE)
  lastActivityAt DateTime @default(now())
  abandonedAt  DateTime?
  // How many recovery steps have already been sent for this cart.
  recoveryStepsSent Int    @default(0)
  lastRecoveryAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  store Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items CartItem[]
  orders Order[]

  @@index([tenantId])
  @@index([storeId])
  @@index([status])
}

model CartItem {
  id             String @id @default(cuid())
  tenantId       String
  cartId         String
  variantId      String
  title          String
  quantity       Int    @default(1)
  unitPriceMinor Int

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@index([cartId])
}

// ---------------------------------------------------------------------------
// Shipping / logistics
// ---------------------------------------------------------------------------

model Shipment {
  id          String         @id @default(cuid())
  tenantId    String
  storeId     String
  orderId     String         @unique
  provider    ProviderName
  status      ShipmentStatus @default(PENDING)
  awb         String?        // tracking / air-waybill number
  courier     String?
  trackingUrl String?
  labelUrl    String?
  codAmountMinor Int?
  weightGrams Int?
  // Shipment-protection / insurance (recorded; no live insurer integration).
  insured            Boolean @default(false)
  insuredAmountMinor Int?
  // Merchant's packed-order video (dispute evidence, QuickBooks-style).
  packingVideoUrl    String?
  toAddress   Json
  fromAddress Json?
  raw         Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  store  Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order  Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events ShipmentEvent[]

  @@index([tenantId])
  @@index([storeId])
  @@index([awb])
}

// Tracking checkpoints for a shipment (newest reflects current status).
model ShipmentEvent {
  id          String         @id @default(cuid())
  shipmentId  String
  status      ShipmentStatus
  description String?
  location    String?
  occurredAt  DateTime       @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
}

// Per-store stock-alert thresholds (drives the R/A/G scorer).
model StockPolicy {
  id                 String   @id @default(cuid())
  tenantId           String
  storeId            String   @unique
  enabled            Boolean  @default(true)
  // Days-of-cover boundaries: >= greenDays is GREEN, >= amberDays is AMBER.
  greenDays          Int      @default(14)
  amberDays          Int      @default(5)
  // Inventory at or below this is always RED (manual reorder point).
  reorderPoint       Int      @default(0)
  // Trailing window (days) used to compute sales velocity.
  velocityWindowDays Int      @default(30)
  updatedAt          DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Per-store abandoned-cart recovery configuration.
model CartRecoveryPolicy {
  id                 String   @id @default(cuid())
  tenantId           String
  storeId            String   @unique
  enabled            Boolean  @default(true)
  // A cart idle for this many minutes becomes ABANDONED.
  abandonAfterMinutes Int     @default(60)
  // Delays (minutes after abandonment) at which each recovery message is sent.
  stepDelaysMinutes  Int[]    @default([0, 1440, 4320])
  updatedAt          DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Platform operator back-office (cross-tenant; distinct from merchant RBAC)
// ---------------------------------------------------------------------------

model PlatformUser {
  id        String       @id @default(cuid())
  email     String       @unique
  name      String?
  role      PlatformRole @default(READ_ONLY)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  sessions PlatformSession[]
}

model PlatformSession {
  id             String   @id @default(cuid())
  platformUserId String
  tokenHash      String   @unique
  expiresAt      DateTime
  lastUsedAt     DateTime?
  createdAt      DateTime @default(now())

  user PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@index([platformUserId])
}

model PlatformMagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

// Audit trail of platform-staff actions (suspensions, staff changes, etc.).
model PlatformAuditLog {
  id             String   @id @default(cuid())
  platformUserId String?
  actorEmail     String
  action         String
  targetType     String?
  targetId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Customer support chatbot
// ---------------------------------------------------------------------------

// Per-store configuration for the storefront support/sales chatbot.
model SupportBotConfig {
  id          String   @id @default(cuid())
  tenantId    String
  storeId     String   @unique
  enabled     Boolean  @default(true)
  displayName String   @default("Assistant")
  greeting    String?
  // Extra persona/instructions appended to the system prompt.
  persona     String?
  updatedAt   DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SupportConversation {
  id            String                    @id @default(cuid())
  tenantId      String
  storeId       String
  customerId    String?
  contactName   String?
  contactEmail  String?
  status        SupportConversationStatus @default(OPEN)
  escalationReason String?
  lastMessageAt DateTime                  @default(now())
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([tenantId])
  @@index([storeId])
  @@index([status])
}

model SupportMessage {
  id             String        @id @default(cuid())
  tenantId       String
  conversationId String
  sender         SupportSender
  body           String
  toolsUsed      String[]      @default([])
  createdAt      DateTime      @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ---------------------------------------------------------------------------
// Product reviews
// ---------------------------------------------------------------------------

model Review {
  id           String       @id @default(cuid())
  tenantId     String
  storeId      String
  productId    String
  customerId   String?
  authorName   String
  authorEmail  String?
  rating       Int          // 1..5
  title        String?
  body         String?
  status       ReviewStatus @default(PENDING)
  // True when tied to a real paid order for this product by this customer.
  verified     Boolean      @default(false)
  merchantReply String?
  repliedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([storeId])
  @@index([productId, status])
}

// ---------------------------------------------------------------------------
// Bundles / "frequently bought together" (conversion offers)
// ---------------------------------------------------------------------------

// A curated set of variants sold together at a saving. When a cart contains
// every item of an active bundle (at the required quantities), the discount is
// auto-applied at checkout. Bundles also drive the storefront "frequently
// bought together" widget on product pages.
model Bundle {
  id            String       @id @default(cuid())
  tenantId      String
  storeId       String
  title         String
  description   String?
  discountType  DiscountType @default(PERCENT)
  discountValue Int          @default(0)
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  store Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items BundleItem[]

  @@index([tenantId])
  @@index([storeId])
}

model BundleItem {
  id        String @id @default(cuid())
  tenantId  String
  bundleId  String
  variantId String
  quantity  Int    @default(1)

  bundle  Bundle         @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([bundleId, variantId])
  @@index([bundleId])
}

// ---------------------------------------------------------------------------
// Store design / page builder
// ---------------------------------------------------------------------------

// A merchant- (or agent-) authored storefront page. `sections` is an ordered
// list of typed blocks (hero, rich_text, product_grid, image, featured_product,
// faq) stored as JSON; the storefront renders them and the builder edits them.
// The page with slug "home" is the storefront landing page.
model StorePage {
  id              String     @id @default(cuid())
  tenantId        String
  storeId         String
  slug            String
  title           String
  sections        Json       @default("[]")
  metaTitle       String?
  metaDescription String?
  status          PageStatus @default(DRAFT)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, slug])
  @@index([tenantId])
  @@index([storeId, status])
}

// Per-store visual theme (colors, logo text). One row per store; extensible
// design tokens live in `settings`.
model StoreTheme {
  id           String   @id @default(cuid())
  tenantId     String
  storeId      String   @unique
  primaryColor String   @default("#1c1917")
  accentColor  String   @default("#4f46e5")
  logoText     String?
  settings     Json     @default("{}")
  updatedAt    DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Returns / RMA
// ---------------------------------------------------------------------------

// A return request against a paid order. Customers raise it (optionally with an
// unboxing/damage video as evidence); merchants approve/reject, mark the item
// received, and issue a refund through the payment adapter.
model Return {
  id               String       @id @default(cuid())
  tenantId         String
  storeId          String
  orderId          String
  customerId       String?
  number           Int          // sequential RMA number per store
  status           ReturnStatus @default(REQUESTED)
  reason           ReturnReason @default(OTHER)
  comment          String?
  // Customer-supplied unboxing/damage video (dispute evidence).
  evidenceVideoUrl String?
  merchantNote     String?
  refundMinor      Int?
  refundRef        String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  store Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items ReturnItem[]

  @@unique([storeId, number])
  @@index([tenantId])
  @@index([storeId, status])
  @@index([orderId])
}

model ReturnItem {
  id          String @id @default(cuid())
  tenantId    String
  returnId    String
  orderItemId String
  quantity    Int    @default(1)

  return    Return    @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([returnId])
}

// ---------------------------------------------------------------------------
// Loyalty / rewards (LoyaltyLion-style)
// ---------------------------------------------------------------------------

// Per-store points program configuration.
model LoyaltyProgram {
  id                       String   @id @default(cuid())
  tenantId                 String
  storeId                  String   @unique
  enabled                  Boolean  @default(false)
  // Points earned per 1 major currency unit spent (e.g. 1 point per ₹1).
  pointsPerCurrencyUnit    Int      @default(1)
  // Value in minor units each point is worth on redemption (e.g. 10 = ₹0.10).
  redeemValueMinorPerPoint Int      @default(10)
  minRedeemPoints          Int      @default(100)
  signupBonus              Int      @default(0)
  // Tier thresholds by lifetime points: [{ "name": "Gold", "minPoints": 1000 }].
  tiers                    Json     @default("[]")
  updatedAt                DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// A customer's points balance + lifetime total (drives tier).
model LoyaltyAccount {
  id             String   @id @default(cuid())
  tenantId       String
  storeId        String
  customerId     String   @unique
  pointsBalance  Int      @default(0)
  lifetimePoints Int      @default(0)
  tier           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer     Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]

  @@index([tenantId])
  @@index([storeId])
}

// Append-only points ledger. `points` is signed (+earn / -redeem).
model LoyaltyTransaction {
  id        String         @id @default(cuid())
  tenantId  String
  accountId String
  type      LoyaltyTxnType
  points    Int
  note      String?
  orderId   String?
  createdAt DateTime       @default(now())

  account LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([orderId])
}
