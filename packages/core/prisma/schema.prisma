// Agentic Commerce Platform — core domain model.
// Multi-tenant SaaS: every domain row carries a tenantId and is isolated by the service layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum StoreStatus {
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  PARTIALLY_REFUNDED
  REFUNDED
}

// Category of an integration (what the provider does).
enum IntegrationKind {
  PAYMENT
  MESSAGING
  SHIPPING
  MARKETING
}

// Concrete provider implementations available behind the adapter interfaces.
enum ProviderName {
  RAZORPAY
  GOKWIK
  WHATSAPP
  RESEND
  MSG91
  DELHIVERY
  KLAVIYO
  MAILCHIMP
  BREVO
}

// Lifecycle of a shipment (Delhivery-style).
enum ShipmentStatus {
  PENDING            // created locally, no AWB yet
  MANIFESTED         // AWB assigned / handed to courier
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RTO                // return to origin
  CANCELLED
  FAILED
}

// Delivery channels for customer/store-owner notifications.
enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

// Business events that can trigger a notification.
enum NotificationEvent {
  ORDER_PLACED
  ORDER_PAID
  ORDER_STATUS_CHANGED
  ABANDONED_CART
  LOW_STOCK
  OUT_OF_STOCK
  SHIPMENT_CREATED
  OUT_FOR_DELIVERY
  DELIVERED
  REVIEW_REQUEST
  RETURN_REQUESTED
  RETURN_APPROVED
  RETURN_REJECTED
  RETURN_REFUNDED
  SUPPORT_ESCALATED
}

// Lifecycle of a return / RMA.
enum ReturnStatus {
  REQUESTED  // customer asked to return
  APPROVED   // merchant authorized; awaiting the item back
  REJECTED   // merchant declined
  RECEIVED   // returned item received by the merchant
  REFUNDED   // money returned to the customer
  CANCELLED  // withdrawn
}

// Why a customer is returning items.
enum ReturnReason {
  DAMAGED
  WRONG_ITEM
  NOT_AS_DESCRIBED
  NO_LONGER_NEEDED
  OTHER
}

// Kind of loyalty-points ledger entry.
enum LoyaltyTxnType {
  EARN    // earned from a paid order
  REDEEM  // spent for a discount
  SIGNUP  // joining bonus
  ADJUST  // manual merchant adjustment
}

// State of a recurring subscription.
enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

// Billing cadence for a subscription.
enum BillingInterval {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
}

// Moderation state of a product review.
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// How a bundle's saving is expressed.
enum DiscountType {
  PERCENT // discountValue = percent off (0..100)
  FIXED   // discountValue = flat amount off, in minor units
}

// Publish state of a builder-authored storefront page.
enum PageStatus {
  DRAFT
  PUBLISHED
}

// Who a notification is addressed to.
enum RecipientType {
  CUSTOMER
  STORE_OWNER
}

enum NotificationStatus {
  SENT
  FAILED
  SKIPPED
}

// Lifecycle of a shopping cart.
enum CartStatus {
  ACTIVE     // shopper is adding items
  ABANDONED  // idle past the threshold; recovery in progress
  CONVERTED  // checked out and paid (never abandoned)
  RECOVERED  // was abandoned, then converted
}

// Traffic-light stock health for a variant.
enum StockStatus {
  GREEN  // healthy cover
  AMBER  // running low
  RED    // critical / out of stock
}

// Why a variant's inventory changed (the movement ledger / audit trail).
enum StockMovementReason {
  SALE     // consumed by a captured (paid) order
  RETURN   // restocked from a received return
  CANCEL   // restored from a cancelled / refunded paid order
  RECEIVE  // stock received (restock / purchase order)
  ADJUST   // manual correction (recount, shrinkage, damage)
}

// Lifecycle of a stock reservation held between checkout and capture.
enum ReservationStatus {
  ACTIVE   // holding stock for a pending order
  CONSUMED // the order was paid → became a real sale
  RELEASED // the order was cancelled / failed / expired → stock freed
}

// A customer-support conversation's state.
enum SupportConversationStatus {
  OPEN       // bot/customer exchange in progress
  ESCALATED  // flagged for a human agent
  RESOLVED   // closed
}

// Who authored a support message.
enum SupportSender {
  CUSTOMER
  BOT
  AGENT
}

// ---------------------------------------------------------------------------
// Account / tenancy
// ---------------------------------------------------------------------------

// Roles for a user within a tenant, in descending order of privilege.
enum Role {
  OWNER
  ADMIN
  STAFF
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

// Roles for staff of the platform operator (the SaaS company), distinct from
// per-tenant merchant roles.
enum PlatformRole {
  SUPER_ADMIN
  SUPPORT
  BILLING
  READ_ONLY
}

enum PlanTier {
  FREE
  GROWTH
  ENTERPRISE
}

// How much a partner may do on a client's store. The client controls this.
enum PartnerAccessLevel {
  MANAGE // full admin: add / edit / delete across the store
  VIEW   // read-only analytics
  NONE   // no store access (dashboard aggregates only)
}

// Repricing strategy for the pricing-intelligence engine.
enum RepricingStrategy {
  MATCH_LOWEST // price at the lowest competitor
  BEAT_LOWEST  // undercut the lowest competitor by adjustValue
  FIXED_MARGIN // price to hit a target margin off cost (ignores competitors)
}

// A tracked storefront behaviour signal (the cohort-intelligence funnel).
enum BehaviorEventType {
  LAND        // landed on the store (carries acquisition attribution)
  VIEW        // viewed a product
  CLICK       // clicked a product/CTA
  SEARCH      // searched the store (carries the query)
  ADD_TO_CART // added a product to cart
  PURCHASE    // bought (also derived from orders)
}

// How a cohort was formed.
enum CohortKind {
  BEHAVIORAL    // soft-clustered (fuzzy c-means) over behaviour + attribution
  ACQUISITION   // grouped by a Meta campaign or Google search term
  SEARCH_INTENT // grouped by what shoppers searched for on the store
}

// Lifecycle/merchandising moment an engagement automation reacts to. Each has a
// library of 5 ready-to-use templates per channel.
enum EngagementTrigger {
  NEW_IN_STOCK      // freshly added products
  BEST_SELLING      // top sellers / social proof
  SLOW_MOVING       // ageing stock that needs a nudge
  LOW_STOCK         // scarcity / "almost gone"
  BACK_IN_STOCK     // a product the shopper wanted is available again
  DISCOUNT          // a running offer / promo code
  FESTIVE_DISCOUNT  // festive-season campaign (Diwali, etc.)
  ABANDONED_CART    // recover a left-behind cart
  COHORT_OFFER      // cohort-based, hyper-personalised product offer
}

// Outcome of an engagement send decision (drives the frequency/fatigue caps).
enum EngagementSendStatus {
  SENT        // delivered (or simulated in dry-run)
  SUPPRESSED  // held back by frequency cap / cross-cohort dedup
  SKIPPED     // no reachable address or channel not configured
  FAILED      // provider error
}

// External AI shopping assistants the store can be made shoppable through.
enum AgentChannel {
  CLAUDE
  CHATGPT
  GEMINI
  PERPLEXITY
  COPILOT
  META_AI
}

model Tenant {
  id        String       @id @default(cuid())
  name      String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  stores        Store[]
  apiKeys       ApiKey[]
  installations AppInstallation[]
  memberships   Membership[]
  invites       Invite[]
  plan          TenantPlan?
  partnerClient PartnerClient?
  auditLogs     AuditLog[]
}

// Plan tier + feature flags/limits for a tenant, set by platform billing staff.
// (Billing integration itself is out of scope — these are the operator flags.)
model TenantPlan {
  id         String   @id @default(cuid())
  tenantId   String   @unique
  tier       PlanTier @default(FREE)
  // null = unlimited; otherwise the max number of stores allowed.
  storeLimit Int?
  features   String[] @default([])
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// Global user identity. A user can belong to multiple tenants via Membership.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  sessions    Session[]
}

// A user's role within a specific tenant.
model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

// Pending invitation to join a tenant with a given role (passwordless).
model Invite {
  id        String    @id @default(cuid())
  tenantId  String
  email     String
  role      Role      @default(STAFF)
  tokenHash String    @unique
  expiresAt DateTime
  acceptedAt DateTime?
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([email])
}

// Single-use passwordless login token, emailed as a magic link.
model MagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

// An authenticated browser session for the admin console (Bearer token).
model Session {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String
  tokenHash  String   @unique
  expiresAt  DateTime
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  // Only the SHA-256 hash of the raw key is stored. `prefix` is a non-secret
  // lookup hint shown in dashboards (e.g. "sk_live_a1b2").
  keyHash    String    @unique
  prefix     String
  scopes     String[]  @default([])
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Storefront domain
// ---------------------------------------------------------------------------

model Store {
  id        String      @id @default(cuid())
  tenantId  String
  name      String
  slug      String
  domain    String?
  currency  String      @default("INR")
  country   String      @default("IN")
  status    StoreStatus @default(ACTIVE)
  // Where store-owner notifications (stock alerts, new orders) are sent.
  // Phase 2 will derive these from user memberships; explicit for now.
  ownerEmail String?
  ownerPhone String?
  // --- Seller tax identity (printed on GST tax invoices) -------------------
  // Registered legal/business name (falls back to `name` on the invoice).
  legalName    String?
  // 15-char GSTIN. Present => the store is GST-registered and issues tax
  // invoices with split CGST/SGST/IGST; absent => a plain bill of supply.
  gstin        String?
  pan          String?
  // Registered place of business (the seller address on the invoice).
  taxAddressLine1 String?
  taxAddressLine2 String?
  taxCity         String?
  taxState        String?
  // 2-digit Indian state code (e.g. "29" = Karnataka). Drives intra- vs
  // inter-state tax: seller state == place of supply => CGST+SGST, else IGST.
  taxStateCode    String?
  taxPincode      String?
  // Per-store invoice / credit-note number-series prefixes (GST requires a
  // unique, sequential series). Numbers themselves are sequential ints.
  invoicePrefix    String @default("INV")
  creditNotePrefix String @default("CN")
  // Last time cohort intelligence was recomputed (drives the scheduled cadence).
  cohortsRecomputedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenant       Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products     Product[]
  collections  Collection[]
  customers    Customer[]
  orders       Order[]
  integrations IntegrationConfig[]
  notifications Notification[]
  notificationPreferences NotificationPreference[]
  carts        Cart[]
  cartRecoveryPolicy CartRecoveryPolicy?
  stockPolicy  StockPolicy?
  shipments    Shipment[]
  supportConversations SupportConversation[]
  supportBotConfig SupportBotConfig?
  reviews      Review[]
  bundles      Bundle[]
  pages        StorePage[]
  theme        StoreTheme?
  returns      Return[]
  returnPolicy ReturnPolicy?
  listingAgentConfig ListingAgentConfig?
  checkoutSettings CheckoutSettings?
  stockMovements StockMovement[]
  stockReservations StockReservation[]
  loyaltyProgram LoyaltyProgram?
  subscriptions Subscription[]
  subscriptionSettings SubscriptionSettings?
  seoSettings  SeoSettings?
  images       ImageAsset[]
  pricingRule  PricingRule?
  behaviorEvents      BehaviorEvent[]
  cohorts             Cohort[]
  engagementCampaigns EngagementCampaign[]
  engagementPolicy    EngagementPolicy?
  engagementMessages  EngagementMessage[]
  shopabilityConfig   ShopabilityConfig?
  agentCheckouts      AgentCheckout[]
  wishlistItems       WishlistItem[]
  invoices            Invoice[]
  creditNotes         CreditNote[]
  legalPolicies       LegalPolicy[]
  importJobs          ImportJob[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

// A storefront shopper's saved products, keyed by email (guest-friendly).
model WishlistItem {
  id        String   @id @default(cuid())
  tenantId  String
  storeId   String
  email     String
  productId String
  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, email, productId])
  @@index([storeId, email])
}

model Product {
  id          String        @id @default(cuid())
  tenantId    String
  storeId     String
  title       String
  description String?
  status      ProductStatus @default(DRAFT)
  // HSN/SAC classification code, printed per line on the GST tax invoice.
  hsnCode     String?
  // Optional per-product GST rate in basis points (1800 = 18%). When unset the
  // store-level checkout tax rate applies. Snapshotted onto each invoice line.
  gstRateBps  Int?
  // Free-form tags/keywords (set by the listing agent's content writer).
  tags        String[]      @default([])
  // SEO overrides (fall back to store templates/title when unset).
  metaTitle       String?
  metaDescription String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants ProductVariant[]
  reviews  Review[]
  images   ImageAsset[]

  @@index([tenantId])
  @@index([storeId])
}

// The customisable "harness" for the listing agent and its content-writer /
// photo-enhancer sub-agents: a master prompt plus brand-voice/tone/rules and
// photo preferences the store owner can tune. Used to generate product copy and
// enhance photos when listing.
model ListingAgentConfig {
  id            String   @id @default(cuid())
  tenantId      String
  storeId       String   @unique
  masterPrompt  String? // overrides the built-in master prompt template
  brandVoice    String? // e.g. "friendly, premium, a little witty"
  tone          String? // e.g. "concise", "playful", "luxurious"
  categoryHint  String? // default product category, e.g. "apparel"
  contentRules  String[] @default([]) // e.g. ["mention free shipping", "no superlatives"]
  descWords     Int      @default(60) // target description length (words)
  // Photo-enhancer preferences.
  enhanceBackground Boolean @default(true)
  squareCrop        Boolean @default(true)
  autoAltText       Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String  @id @default(cuid())
  tenantId  String
  productId String
  title     String  @default("Default")
  sku       String?
  // Price is stored in the smallest currency unit (paise for INR).
  priceMinor Int
  // Optional "was" price (MRP / list price) shown struck-through to advertise a
  // discount; null = no discount. Always >= priceMinor when set.
  compareAtMinor Int?
  // Unit cost (COGS) in minor units, used for margin analysis & repricing floors.
  costMinor Int     @default(0)
  currency  String  @default("INR")
  inventory Int     @default(0)
  // Units held for not-yet-paid orders (checkout→capture). available = inventory - reserved.
  reserved  Int     @default(0)
  options   Json?
  // Last computed stock health, used to detect transitions for alerting.
  lastStockStatus StockStatus?

  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
  bundleItems      BundleItem[]
  subscriptions    Subscription[]
  competitorPrices CompetitorPrice[]
  stockMovements   StockMovement[]
  reservations     StockReservation[]

  @@index([tenantId])
  @@index([productId])
}

model Collection {
  id        String   @id @default(cuid())
  tenantId  String
  storeId   String
  title     String
  handle    String
  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, handle])
  @@index([tenantId])
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  storeId   String
  name      String?
  email     String?
  phone     String?
  // Lightweight CRM: merchant-applied tags and free-form notes.
  tags      String[] @default([])
  notes     String?
  // First-touch acquisition attribution (e.g. source=meta, campaign="Summer Sale";
  // or source=google, term="running shoes").
  acqSource   String?
  acqCampaign String?
  acqTerm     String?
  // Marketing consent (gates promotional engagement, not transactional notices).
  // Explicit opt-in required; an unsubscribe always overrides consent.
  marketingConsent   Boolean   @default(false)
  marketingConsentAt DateTime?
  unsubscribedAt     DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders         Order[]
  loyaltyAccount LoyaltyAccount?
  subscriptions  Subscription[]
  behaviorEvents     BehaviorEvent[]
  cohortMemberships  CohortMembership[]
  engagementMessages EngagementMessage[]

  @@index([tenantId])
  @@index([storeId])
}

model Order {
  id         String      @id @default(cuid())
  tenantId   String
  storeId    String
  number     Int
  customerId String?
  // Set when an order originates from a cart, so recovery can be attributed.
  cartId     String?
  status     OrderStatus @default(PENDING)
  // Item subtotal (before discount/tax/shipping). totalMinor is the amount
  // actually charged = subtotal - discount + tax + shipping.
  subtotalMinor Int      @default(0)
  totalMinor Int
  // Bundle/offer savings applied at checkout, in minor units (0 = none).
  discountMinor Int      @default(0)
  taxMinor      Int      @default(0)
  shippingMinor Int      @default(0)
  currency   String      @default("INR")
  // Buyer contact + delivery address captured at checkout.
  email           String?
  shippingAddress Json?
  // Sales-channel attribution. source: e.g. "agent" (AI assistant), null = web/direct.
  // agentChannel names the assistant when source = "agent".
  source       String?
  agentChannel AgentChannel?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  store    Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  cart     Cart?       @relation(fields: [cartId], references: [id], onDelete: SetNull)
  items    OrderItem[]
  payment  Payment?
  shipment Shipment?
  returns  Return[]
  invoice  Invoice?
  creditNotes CreditNote[]

  @@unique([storeId, number])
  @@index([tenantId])
  @@index([storeId])
  @@index([cartId])
}

model OrderItem {
  id             String  @id @default(cuid())
  tenantId       String
  orderId        String
  variantId      String?
  title          String
  quantity       Int     @default(1)
  unitPriceMinor Int

  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  returnItems ReturnItem[]

  @@index([orderId])
}

model Payment {
  id          String        @id @default(cuid())
  tenantId    String
  orderId     String        @unique
  provider    ProviderName
  providerRef String?
  status      PaymentStatus @default(PENDING)
  amountMinor Int
  // Cumulative amount refunded so far (caps total refunds at the order value).
  refundedMinor Int         @default(0)
  currency    String        @default("INR")
  raw         Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([providerRef])
}

// ---------------------------------------------------------------------------
// Integrations (pluggable adapters)
// ---------------------------------------------------------------------------

model IntegrationConfig {
  id        String          @id @default(cuid())
  tenantId  String
  storeId   String
  kind      IntegrationKind
  provider  ProviderName
  // Credentials are encrypted at rest (AES-256-GCM) before being stored here.
  config    Json
  enabled   Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, provider])
  @@index([tenantId])
}

model WebhookEvent {
  id             String       @id @default(cuid())
  tenantId       String?
  provider       ProviderName
  eventType      String?
  signatureValid Boolean      @default(false)
  payload        Json
  receivedAt     DateTime     @default(now())

  @@index([provider])
}

// ---------------------------------------------------------------------------
// Partner app ecosystem (schema stubbed; minimal logic in Milestone 1)
// ---------------------------------------------------------------------------

model App {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  developer   String?
  category    String?
  scopes      String[] @default([]) // permissions the app requests at install
  webhookUrl  String? // where the app receives events (delivery is a stub for now)
  published   Boolean  @default(true) // visible in the merchant catalog
  createdAt   DateTime @default(now())

  installations AppInstallation[]
}

// Merchant-side audit trail: who (owner / staff / API key / partner) changed what
// within a tenant. Distinct from PlatformAuditLog (operator actions). Especially
// important now that partners can edit client stores under delegated access.
model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  actorKind  String // user | apiKey | partner
  actorId    String? // userId / partnerId (null for an API key)
  action     String // e.g. "product.update", "shopability.update"
  method     String
  path       String
  resource   String? // route base, e.g. "products"
  resourceId String? // the :id route param, when present
  statusCode Int
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model AppInstallation {
  id        String   @id @default(cuid())
  tenantId  String
  appId     String
  enabled   Boolean  @default(true)
  scopes    String[] @default([]) // scopes granted to the app at install time
  config    Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  app    App    @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([tenantId, appId])
  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Notifications (email / SMS / WhatsApp to customers and store owners)
// ---------------------------------------------------------------------------

// Per-store override of the message body for an (event, channel). When absent,
// a built-in default template (in code) is used, so seeding is optional.
model NotificationTemplate {
  id        String              @id @default(cuid())
  tenantId  String
  storeId   String
  event     NotificationEvent
  channel   NotificationChannel
  subject   String?
  body      String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([storeId, event, channel])
  @@index([tenantId])
}

// Which channels fire for an (event, recipient) in a store. When absent, a
// built-in default preference (in code) decides.
model NotificationPreference {
  id            String                @id @default(cuid())
  tenantId      String
  storeId       String
  event         NotificationEvent
  recipientType RecipientType
  channels      NotificationChannel[] @default([])
  enabled       Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, event, recipientType])
  @@index([tenantId])
}

// Audit log of every notification dispatch attempt.
model Notification {
  id            String              @id @default(cuid())
  tenantId      String
  storeId       String
  event         NotificationEvent
  channel       NotificationChannel
  recipientType RecipientType
  to            String
  status        NotificationStatus
  providerRef   String?
  error         String?
  createdAt     DateTime            @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([storeId])
}

// ---------------------------------------------------------------------------
// Carts & abandoned-cart recovery
// ---------------------------------------------------------------------------

model Cart {
  id           String     @id @default(cuid())
  tenantId     String
  storeId      String
  customerId   String?
  // Contact for an anonymous shopper (used for recovery messages).
  contactEmail String?
  contactPhone String?
  status       CartStatus @default(ACTIVE)
  lastActivityAt DateTime @default(now())
  abandonedAt  DateTime?
  // How many recovery steps have already been sent for this cart.
  recoveryStepsSent Int    @default(0)
  lastRecoveryAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  store Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items CartItem[]
  orders Order[]

  @@index([tenantId])
  @@index([storeId])
  @@index([status])
}

model CartItem {
  id             String @id @default(cuid())
  tenantId       String
  cartId         String
  variantId      String
  title          String
  quantity       Int    @default(1)
  unitPriceMinor Int

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@index([cartId])
}

// ---------------------------------------------------------------------------
// Shipping / logistics
// ---------------------------------------------------------------------------

model Shipment {
  id          String         @id @default(cuid())
  tenantId    String
  storeId     String
  orderId     String         @unique
  provider    ProviderName
  status      ShipmentStatus @default(PENDING)
  awb         String?        // tracking / air-waybill number
  courier     String?
  trackingUrl String?
  labelUrl    String?
  codAmountMinor Int?
  weightGrams Int?
  // Shipment-protection / insurance (recorded; no live insurer integration).
  insured            Boolean @default(false)
  insuredAmountMinor Int?
  // Merchant's packed-order video (dispute evidence, QuickBooks-style).
  packingVideoUrl    String?
  toAddress   Json
  fromAddress Json?
  raw         Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  store  Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order  Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events ShipmentEvent[]

  @@index([tenantId])
  @@index([storeId])
  @@index([awb])
}

// Tracking checkpoints for a shipment (newest reflects current status).
model ShipmentEvent {
  id          String         @id @default(cuid())
  shipmentId  String
  status      ShipmentStatus
  description String?
  location    String?
  occurredAt  DateTime       @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
}

// Per-store tax & shipping configuration applied at checkout.
model CheckoutSettings {
  id                    String   @id @default(cuid())
  tenantId              String
  storeId               String   @unique
  // Tax rate in basis points (1800 = 18% GST). 0 = no tax.
  taxBps                Int      @default(0)
  taxLabel              String   @default("Tax")
  // When true, product prices already include tax (extract it; total unchanged).
  pricesIncludeTax      Boolean  @default(false)
  // Flat shipping fee (minor units); 0 = free shipping.
  flatShippingMinor     Int      @default(0)
  // Order subtotal (after discount) at/above which shipping is free; null = never.
  freeShippingOverMinor Int?
  requireAddress        Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

// Per-store stock-alert thresholds (drives the R/A/G scorer).
model StockPolicy {
  id                 String   @id @default(cuid())
  tenantId           String
  storeId            String   @unique
  enabled            Boolean  @default(true)
  // Days-of-cover boundaries: >= greenDays is GREEN, >= amberDays is AMBER.
  greenDays          Int      @default(14)
  amberDays          Int      @default(5)
  // Inventory at or below this is always RED (manual reorder point).
  reorderPoint       Int      @default(0)
  // Trailing window (days) used to compute sales velocity.
  velocityWindowDays Int      @default(30)
  // Whether stock is consumed by sales + enforced at checkout. Off = untracked
  // (digital / made-to-order): no decrement, no oversell block.
  trackInventory     Boolean  @default(true)
  // When tracking, allow checkout beyond available stock (inventory may go
  // negative = backorder) instead of blocking the order.
  allowBackorder     Boolean  @default(false)
  updatedAt          DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Inventory movement ledger: one row per change to a variant's stock, with the
// reason, the resulting balance, and who/what caused it — the audit trail.
model StockMovement {
  id        String              @id @default(cuid())
  tenantId  String
  storeId   String
  variantId String
  delta     Int // signed change actually applied (+receive / -sale)
  balance   Int // resulting inventory after the move
  reason    StockMovementReason
  note      String?
  orderId   String?
  returnId  String?
  actorKind String? // user | apiKey | partner | system
  actorId   String?
  createdAt DateTime            @default(now())

  store   Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([storeId, createdAt])
  @@index([variantId, createdAt])
}

// A hold on stock for a pending order, from checkout until capture. Consumed on
// payment, released on cancel/fail/expiry. Backs the race-safe overselling guard.
model StockReservation {
  id        String            @id @default(cuid())
  tenantId  String
  storeId   String
  orderId   String
  variantId String
  quantity  Int
  status    ReservationStatus @default(ACTIVE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  store   Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([storeId, status])
  @@index([variantId, status])
}

// Per-store abandoned-cart recovery configuration.
model CartRecoveryPolicy {
  id                 String   @id @default(cuid())
  tenantId           String
  storeId            String   @unique
  enabled            Boolean  @default(true)
  // A cart idle for this many minutes becomes ABANDONED.
  abandonAfterMinutes Int     @default(60)
  // Delays (minutes after abandonment) at which each recovery message is sent.
  stepDelaysMinutes  Int[]    @default([0, 1440, 4320])
  updatedAt          DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Platform operator back-office (cross-tenant; distinct from merchant RBAC)
// ---------------------------------------------------------------------------

model PlatformUser {
  id        String       @id @default(cuid())
  email     String       @unique
  name      String?
  role      PlatformRole @default(READ_ONLY)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  sessions PlatformSession[]
}

model PlatformSession {
  id             String   @id @default(cuid())
  platformUserId String
  tokenHash      String   @unique
  expiresAt      DateTime
  lastUsedAt     DateTime?
  createdAt      DateTime @default(now())

  user PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@index([platformUserId])
}

model PlatformMagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

// Audit trail of platform-staff actions (suspensions, staff changes, etc.).
model PlatformAuditLog {
  id             String   @id @default(cuid())
  platformUserId String?
  actorEmail     String
  action         String
  targetType     String?
  targetId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Customer support chatbot
// ---------------------------------------------------------------------------

// Per-store configuration for the storefront support/sales chatbot.
model SupportBotConfig {
  id          String   @id @default(cuid())
  tenantId    String
  storeId     String   @unique
  enabled     Boolean  @default(true)
  displayName String   @default("Assistant")
  greeting    String?
  // Extra persona/instructions appended to the system prompt.
  persona     String?
  updatedAt   DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SupportConversation {
  id            String                    @id @default(cuid())
  tenantId      String
  storeId       String
  customerId    String?
  contactName   String?
  contactEmail  String?
  status        SupportConversationStatus @default(OPEN)
  escalationReason String?
  lastMessageAt DateTime                  @default(now())
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([tenantId])
  @@index([storeId])
  @@index([status])
}

model SupportMessage {
  id             String        @id @default(cuid())
  tenantId       String
  conversationId String
  sender         SupportSender
  body           String
  toolsUsed      String[]      @default([])
  createdAt      DateTime      @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ---------------------------------------------------------------------------
// Product reviews
// ---------------------------------------------------------------------------

model Review {
  id           String       @id @default(cuid())
  tenantId     String
  storeId      String
  productId    String
  customerId   String?
  authorName   String
  authorEmail  String?
  rating       Int          // 1..5
  title        String?
  body         String?
  status       ReviewStatus @default(PENDING)
  // True when tied to a real paid order for this product by this customer.
  verified     Boolean      @default(false)
  merchantReply String?
  repliedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([storeId])
  @@index([productId, status])
}

// ---------------------------------------------------------------------------
// Bundles / "frequently bought together" (conversion offers)
// ---------------------------------------------------------------------------

// A curated set of variants sold together at a saving. When a cart contains
// every item of an active bundle (at the required quantities), the discount is
// auto-applied at checkout. Bundles also drive the storefront "frequently
// bought together" widget on product pages.
model Bundle {
  id            String       @id @default(cuid())
  tenantId      String
  storeId       String
  title         String
  description   String?
  discountType  DiscountType @default(PERCENT)
  discountValue Int          @default(0)
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  store Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items BundleItem[]

  @@index([tenantId])
  @@index([storeId])
}

model BundleItem {
  id        String @id @default(cuid())
  tenantId  String
  bundleId  String
  variantId String
  quantity  Int    @default(1)

  bundle  Bundle         @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([bundleId, variantId])
  @@index([bundleId])
}

// ---------------------------------------------------------------------------
// Store design / page builder
// ---------------------------------------------------------------------------

// A merchant- (or agent-) authored storefront page. `sections` is an ordered
// list of typed blocks (hero, rich_text, product_grid, image, featured_product,
// faq) stored as JSON; the storefront renders them and the builder edits them.
// The page with slug "home" is the storefront landing page.
model StorePage {
  id              String     @id @default(cuid())
  tenantId        String
  storeId         String
  slug            String
  title           String
  sections        Json       @default("[]")
  metaTitle       String?
  metaDescription String?
  status          PageStatus @default(DRAFT)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, slug])
  @@index([tenantId])
  @@index([storeId, status])
}

// Per-store visual theme (colors, logo text). One row per store; extensible
// design tokens live in `settings`.
model StoreTheme {
  id           String   @id @default(cuid())
  tenantId     String
  storeId      String   @unique
  primaryColor String   @default("#1c1917")
  accentColor  String   @default("#4f46e5")
  logoText     String?
  settings     Json     @default("{}")
  updatedAt    DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Returns / RMA
// ---------------------------------------------------------------------------

// A return request against a paid order. Customers raise it (optionally with an
// unboxing/damage video as evidence); merchants approve/reject, mark the item
// received, and issue a refund through the payment adapter.
model Return {
  id               String       @id @default(cuid())
  tenantId         String
  storeId          String
  orderId          String
  customerId       String?
  number           Int          // sequential RMA number per store
  status           ReturnStatus @default(REQUESTED)
  reason           ReturnReason @default(OTHER)
  comment          String?
  // Customer-supplied unboxing/damage video (dispute evidence).
  evidenceVideoUrl String?
  merchantNote     String?
  refundMinor      Int?
  refundRef        String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  store Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items ReturnItem[]
  creditNote CreditNote?

  @@unique([storeId, number])
  @@index([tenantId])
  @@index([storeId, status])
  @@index([orderId])
}

model ReturnItem {
  id          String @id @default(cuid())
  tenantId    String
  returnId    String
  orderItemId String
  quantity    Int    @default(1)

  return    Return    @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([returnId])
}

// Per-store return & cancellation policy the system enforces (window, eligible
// reasons, restocking fee, auto-approval, and the buyer self-cancel window).
model ReturnPolicy {
  id                       String         @id @default(cuid())
  tenantId                 String
  storeId                  String         @unique
  enabled                  Boolean        @default(true) // accept returns at all
  returnWindowDays         Int            @default(30) // 0 = no time limit
  eligibleReasons          ReturnReason[] @default([DAMAGED, WRONG_ITEM, NOT_AS_DESCRIBED, NO_LONGER_NEEDED, OTHER])
  restockingFeePercent     Int            @default(0) // deducted from the refund
  autoApprove              Boolean        @default(false) // approve in-policy requests automatically
  // Buyer self-cancellation.
  cancelEnabled            Boolean        @default(true)
  cancelWindowHours        Int            @default(24) // 0 = no time limit
  allowCancelAfterShipment Boolean        @default(false)
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Loyalty / rewards (LoyaltyLion-style)
// ---------------------------------------------------------------------------

// Per-store points program configuration.
model LoyaltyProgram {
  id                       String   @id @default(cuid())
  tenantId                 String
  storeId                  String   @unique
  enabled                  Boolean  @default(false)
  // Points earned per 1 major currency unit spent (e.g. 1 point per ₹1).
  pointsPerCurrencyUnit    Int      @default(1)
  // Value in minor units each point is worth on redemption (e.g. 10 = ₹0.10).
  redeemValueMinorPerPoint Int      @default(10)
  minRedeemPoints          Int      @default(100)
  signupBonus              Int      @default(0)
  // Tier thresholds by lifetime points: [{ "name": "Gold", "minPoints": 1000 }].
  tiers                    Json     @default("[]")
  updatedAt                DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// A customer's points balance + lifetime total (drives tier).
model LoyaltyAccount {
  id             String   @id @default(cuid())
  tenantId       String
  storeId        String
  customerId     String   @unique
  pointsBalance  Int      @default(0)
  lifetimePoints Int      @default(0)
  tier           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer     Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]

  @@index([tenantId])
  @@index([storeId])
}

// Append-only points ledger. `points` is signed (+earn / -redeem).
model LoyaltyTransaction {
  id        String         @id @default(cuid())
  tenantId  String
  accountId String
  type      LoyaltyTxnType
  points    Int
  note      String?
  orderId   String?
  createdAt DateTime       @default(now())

  account LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([orderId])
}

// ---------------------------------------------------------------------------
// Subscriptions ("subscribe & save" / recurring orders)
// ---------------------------------------------------------------------------

// Per-store subscription settings (the storefront "subscribe & save" offer).
model SubscriptionSettings {
  id              String   @id @default(cuid())
  tenantId        String
  storeId         String   @unique
  enabled         Boolean  @default(false)
  // Default subscribe-and-save discount (percent off each recurring order).
  discountPercent Int      @default(10)
  // Billing intervals offered to shoppers, as JSON: ["WEEKLY","MONTHLY"].
  intervals       Json     @default("[\"WEEKLY\",\"MONTHLY\"]")
  updatedAt       DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// A customer's recurring order for one variant at a fixed cadence. The worker
// generates a discounted order on each due date and advances nextBillingAt.
model Subscription {
  id              String             @id @default(cuid())
  tenantId        String
  storeId         String
  customerId      String
  variantId       String
  quantity        Int                @default(1)
  interval        BillingInterval    @default(MONTHLY)
  discountPercent Int                @default(0)
  status          SubscriptionStatus @default(ACTIVE)
  nextBillingAt   DateTime
  cyclesCompleted Int                @default(0)
  lastOrderId     String?
  canceledAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  store    Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([storeId, status])
  @@index([status, nextBillingAt])
  @@index([customerId])
}

// ---------------------------------------------------------------------------
// SEO & image optimization (Plug-in-SEO / TinyIMG-style)
// ---------------------------------------------------------------------------

// Per-store SEO defaults that drive meta tags, sitemap, and robots.
model SeoSettings {
  id                 String   @id @default(cuid())
  tenantId           String
  storeId            String   @unique
  // Title template; {title} and {storeName} are substituted.
  titleTemplate      String   @default("{title} | {storeName}")
  defaultDescription String?
  // When false, robots.txt disallows crawling and pages are marked noindex.
  indexable          Boolean  @default(true)
  updatedAt          DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// A managed image asset. Optimization records the byte savings (compression is
// simulated here; a real image pipeline slots in behind the same fields).
model ImageAsset {
  id             String   @id @default(cuid())
  tenantId       String
  storeId        String
  productId      String?
  url            String
  alt            String?
  originalBytes  Int
  optimizedBytes Int?
  optimized      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store   Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([storeId])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// Partner / agency dashboard
// ---------------------------------------------------------------------------

// An agency/reseller that manages client stores and earns commission on their
// GMV. Separate identity plane (magic-link), like platform staff.
model Partner {
  id                String   @id @default(cuid())
  name              String
  email             String   @unique
  // The partner's commission on client GMV, in percent.
  commissionPercent Int      @default(10)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  clients  PartnerClient[]
  sessions PartnerSession[]
}

// Links a partner to a client tenant, with the recurring fee the client pays
// and the next renewal date (drives the "upcoming renewals" view).
model PartnerClient {
  id              String             @id @default(cuid())
  partnerId       String
  tenantId        String             @unique
  monthlyFeeMinor Int                @default(0)
  renewsAt        DateTime?
  // What the partner may do on this client's store (client-controlled).
  accessLevel     PartnerAccessLevel @default(MANAGE)
  createdAt       DateTime           @default(now())

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([partnerId])
}

model PartnerSession {
  id         String    @id @default(cuid())
  partnerId  String
  tokenHash  String    @unique
  expiresAt  DateTime
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
}

model PartnerMagicLinkToken {
  id         String    @id @default(cuid())
  email      String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
}

// ---------------------------------------------------------------------------
// Pricing intelligence (competitor tracking + repricing + margin analysis)
// ---------------------------------------------------------------------------

// A tracked competitor price for one of our variants. Refresh is simulated here;
// a real scraper/feed drops in behind the same fields.
model CompetitorPrice {
  id             String   @id @default(cuid())
  tenantId       String
  storeId        String
  variantId      String
  competitorName String
  url            String?
  priceMinor     Int
  inStock        Boolean  @default(true)
  checkedAt      DateTime @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([storeId])
  @@index([variantId])
}

// Per-store automatic repricing rule, bounded by a minimum-margin floor.
model PricingRule {
  id              String            @id @default(cuid())
  tenantId        String
  storeId         String            @unique
  enabled         Boolean           @default(false)
  strategy        RepricingStrategy @default(BEAT_LOWEST)
  // For BEAT_LOWEST: percent (1 = 1% under) when adjustIsPercent, else flat minor.
  // For FIXED_MARGIN: the target margin percent.
  adjustValue     Int               @default(1)
  adjustIsPercent Boolean           @default(true)
  // Never price below the price that yields this margin off cost.
  minMarginPercent Int              @default(10)
  // Charm pricing: round the computed price to end in .99.
  roundTo99       Boolean           @default(false)
  updatedAt       DateTime          @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Cohort intelligence (behaviour tracking + ML micro-cohorts)
// ---------------------------------------------------------------------------

// A storefront behaviour signal. Pre-identification events carry an anonymousId
// (visitor/session); when the shopper is identified, events are linked to the
// customer. LAND events carry the acquisition attribution.
model BehaviorEvent {
  id          String            @id @default(cuid())
  tenantId    String
  storeId     String
  customerId  String?
  anonymousId String?
  type        BehaviorEventType
  productId   String?
  variantId   String?
  source      String?
  medium      String?
  campaign    String?
  term        String?
  query       String? // on-site search query (for SEARCH events)
  createdAt   DateTime          @default(now())

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([storeId, type])
  @@index([customerId])
  @@index([anonymousId])
}

// A computed micro-cohort. `signature` holds the cohort's dominant signals
// (channel, behaviour profile, value tier, top products). Members join via
// CohortMembership with a soft `weight` — a customer can be in many cohorts.
model Cohort {
  id        String     @id @default(cuid())
  tenantId  String
  storeId   String
  kind      CohortKind
  key       String
  label     String
  signature Json       @default("{}")
  size      Int        @default(0)
  updatedAt DateTime   @updatedAt

  store   Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  members CohortMembership[]

  @@unique([storeId, key])
  @@index([tenantId])
  @@index([storeId])
}

model CohortMembership {
  id         String @id @default(cuid())
  tenantId   String
  cohortId   String
  customerId String
  weight     Float  @default(1)

  cohort   Cohort   @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([cohortId, customerId])
  @@index([customerId])
}

// A configured engagement automation: one trigger on one channel. `templateKey`
// optionally pins a specific template variant; when null the hyper-personalisation
// agent rotates/selects the best of the 5 variants per customer. Audience can be
// narrowed by customer temperature and/or a specific cohort.
model EngagementCampaign {
  id           String              @id @default(cuid())
  tenantId     String
  storeId      String
  trigger      EngagementTrigger
  channel      NotificationChannel
  enabled      Boolean             @default(true)
  templateKey  String? // pin a variant; null = auto/rotate
  temperatures String[]            @default([]) // HOT/WARM/COLD filter; empty = all
  cohortKey    String? // restrict to a cohort (esp. COHORT_OFFER)
  priority     Int                 @default(0) // higher wins cross-trigger dedup
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, trigger, channel])
  @@index([tenantId])
  @@index([storeId, enabled])
}

// Per-store messaging-frequency policy. The frequency-adjustment agent caps how
// many promotional touches a customer gets per rolling 7 days by temperature
// (HOT shoppers tolerate more, COLD far fewer), and a per-day cap plus a minimum
// gap stop over-messaging customers who match many cohorts/campaigns at once.
model EngagementPolicy {
  id                  String   @id @default(cuid())
  tenantId            String
  storeId             String   @unique
  enabled             Boolean  @default(true)
  hotMaxPer7Days      Int      @default(4)
  warmMaxPer7Days     Int      @default(2)
  coldMaxPer7Days     Int      @default(1)
  perCustomerDailyCap Int      @default(1) // cross-cohort: at most N messages/day total
  minHoursBetween     Int      @default(20) // minimum gap between any two messages
  quietStartHour      Int      @default(21) // local-ish quiet window start (no sends)
  quietEndHour        Int      @default(8) // quiet window end
  lastRunAt           DateTime? // last automated run (daily cadence guard)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

// Per-store "shopability": whether the catalog is exposed to external AI shopping
// assistants (Claude, ChatGPT, Gemini, …) via the public agent-commerce surface,
// and which assistants specifically. Independent of the human storefront, so a
// store can be open on the web but closed to agents (or the reverse).
model ShopabilityConfig {
  id              String         @id @default(cuid())
  tenantId        String
  storeId         String         @unique
  enabled         Boolean        @default(true) // master agentic-commerce switch
  enabledChannels AgentChannel[] @default([CLAUDE, CHATGPT, GEMINI, PERPLEXITY, COPILOT, META_AI])
  agentNote       String? // optional guidance surfaced to AI agents in the manifest
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Audit of agent-initiated checkouts. Records the delegated-payment mandate the
// buyer's AI agent presented (authorization to pay up to a cap) and which
// assistant drove the purchase — both for enforcement and revenue attribution.
model AgentCheckout {
  id             String        @id @default(cuid())
  tenantId       String
  storeId        String
  cartId         String
  orderId        String?
  channel        AgentChannel?
  mandateRef     String
  maxAmountMinor Int
  amountMinor    Int
  currency       String
  status         String // AUTHORIZED | REJECTED
  reason         String?
  createdAt      DateTime      @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([storeId, createdAt])
}

// Send log — the source of truth for frequency capping, dedup, and the audit UI.
model EngagementMessage {
  id          String               @id @default(cuid())
  tenantId    String
  storeId     String
  customerId  String?
  trigger     EngagementTrigger
  channel     NotificationChannel
  templateKey String
  temperature String? // HOT/WARM/COLD at send time
  to          String
  body        String
  status      EngagementSendStatus
  reason      String? // suppression/skip/failure reason
  providerRef String?
  productIds  String[]             @default([]) // products featured in the message
  dryRun      Boolean              @default(false)
  createdAt   DateTime             @default(now())

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([storeId, status, createdAt])
  @@index([customerId, createdAt])
}

// ---------------------------------------------------------------------------
// GST tax invoicing & accounting
// ---------------------------------------------------------------------------

// A GST tax invoice for a paid order. One per order, generated on payment
// capture. Snapshots the seller's tax identity, the buyer's details, the place
// of supply, and the per-line HSN + taxable value + split CGST/SGST (intra-
// state) or IGST (inter-state) so the document is a permanent, self-contained
// legal record even if the store or product later changes.
model Invoice {
  id        String   @id @default(cuid())
  tenantId  String
  storeId   String
  orderId   String   @unique
  // Sequential per store (GST: unique + sequential within the series).
  number    Int
  // Formatted, human-facing number, e.g. "INV-0001".
  invoiceNo String
  issuedAt  DateTime @default(now())

  // --- Seller snapshot (at issue time) ---
  sellerName      String
  sellerLegalName String?
  sellerGstin     String?
  sellerPan       String?
  sellerAddress   Json?   // { line1, line2, city, state, stateCode, pincode }
  sellerStateCode String?

  // --- Buyer snapshot ---
  buyerName    String?
  buyerEmail   String?
  buyerGstin   String?  // present => B2B (registered buyer)
  buyerAddress Json?    // shipping address used for place of supply

  // --- Place of supply (drives the tax split) ---
  placeOfSupply     String?  // state name
  placeOfSupplyCode String?  // 2-digit state code
  // True when seller state == place of supply => CGST + SGST; else IGST.
  intraState        Boolean  @default(false)
  // True when the seller is GST-registered (a tax invoice vs a bill of supply).
  isTaxInvoice      Boolean  @default(false)

  currency      String @default("INR")
  // All amounts in minor units (paise). Reconciles to the order total.
  subtotalMinor Int        // sum of line taxable values (pre-tax)
  discountMinor Int    @default(0)
  taxableMinor  Int        // taxable value the tax was charged on
  cgstMinor     Int    @default(0)
  sgstMinor     Int    @default(0)
  igstMinor     Int    @default(0)
  taxMinor      Int    @default(0) // cgst + sgst + igst
  shippingMinor Int    @default(0)
  roundOffMinor Int    @default(0)
  totalMinor    Int

  store Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lines InvoiceLine[]
  creditNotes CreditNote[]

  @@unique([storeId, number])
  @@unique([storeId, invoiceNo])
  @@index([tenantId])
  @@index([storeId, issuedAt])
}

model InvoiceLine {
  id        String @id @default(cuid())
  tenantId  String
  invoiceId String
  title     String
  hsnCode   String?
  quantity  Int    @default(1)
  // Tax-exclusive unit price + the line's taxable value (after its discount share).
  unitPriceMinor Int
  taxableMinor   Int
  // GST rate applied to this line, in basis points (1800 = 18%).
  gstRateBps Int   @default(0)
  cgstMinor  Int   @default(0)
  sgstMinor  Int   @default(0)
  igstMinor  Int   @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// A GST credit note issued when a (paid, invoiced) order is refunded — fully or
// partially — through a return or buyer cancellation. Reverses the invoiced tax
// proportionally and carries its own sequential number series.
model CreditNote {
  id           String   @id @default(cuid())
  tenantId     String
  storeId      String
  invoiceId    String
  orderId      String
  returnId     String?  @unique
  number       Int
  creditNoteNo String
  issuedAt     DateTime @default(now())
  reason       String?

  currency      String @default("INR")
  // Amounts reversed (minor units).
  taxableMinor Int
  cgstMinor    Int @default(0)
  sgstMinor    Int @default(0)
  igstMinor    Int @default(0)
  taxMinor     Int @default(0)
  shippingMinor Int @default(0)
  totalMinor   Int
  intraState   Boolean @default(false)

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  return  Return? @relation(fields: [returnId], references: [id], onDelete: SetNull)

  @@unique([storeId, number])
  @@unique([storeId, creditNoteNo])
  @@index([tenantId])
  @@index([storeId, issuedAt])
}

// ---------------------------------------------------------------------------
// Legal pages (terms of use, privacy, shipping, refund/returns, cookies)
// ---------------------------------------------------------------------------

enum LegalPolicyType {
  TERMS    // Terms of Use / Service
  PRIVACY  // Privacy Policy
  SHIPPING // Shipping & Delivery Policy
  REFUND   // Return, Refund & Cancellation Policy
  COOKIES  // Cookie Policy
}

// A store's legal/policy document. One per (store, type). Generated from
// India/GST-aware templates (seller identity + return policy) and editable, then
// published and linked in the storefront footer + checkout. `version` bumps on
// every body change so a buyer's acceptance can reference a specific revision.
model LegalPolicy {
  id          String          @id @default(cuid())
  tenantId    String
  storeId     String
  type        LegalPolicyType
  title       String
  body        String          // long-form text/markdown
  version     Int             @default(1)
  status      PageStatus      @default(DRAFT)
  // True when the body still matches the generated template (no manual edits).
  generated   Boolean         @default(false)
  publishedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, type])
  @@index([tenantId])
  @@index([storeId, status])
}

// ---------------------------------------------------------------------------
// Store migration / bootstrap (import from Shopify, WooCommerce, Dukaan)
// ---------------------------------------------------------------------------

enum ImportSource {
  SHOPIFY
  WOOCOMMERCE
  DUKAAN
  GENERIC // generic CSV / JSON in the platform's own shape
}

enum ImportStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// One run of the bootstrap/migration agent: parses an export from another
// platform and creates products/customers on the store. Idempotent + resumable
// (existing items are skipped), with a per-row report for auditability.
model ImportJob {
  id        String       @id @default(cuid())
  tenantId  String
  storeId   String
  source    ImportSource
  status    ImportStatus @default(PENDING)
  dryRun    Boolean      @default(false)
  productsCreated  Int    @default(0)
  productsSkipped  Int    @default(0)
  customersCreated Int    @default(0)
  customersSkipped Int    @default(0)
  failed           Int    @default(0)
  // Per-row outcomes: [{ kind, name, status: created|skipped|failed, reason }].
  report    Json?
  error     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([storeId, createdAt])
}
